CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Payments (choose per market) ────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # global / Europe / USA
RAZORPAY_KEY_ID=                        # India
TELR_STORE_ID=                          # UAE / Saudi

# ─── Site ────────────────────────────────────────────────────────────────────
